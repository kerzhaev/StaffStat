{
    "files.encoding": "windows1251",
    "files.autoGuessEncoding": false,

    // Настройки именно для VBA файлов
    "[vb]": {
        "files.encoding": "windows1251"
    },
    // Ассоциации, чтобы VS Code понимал, что это VB
    "files.associations": {
        "*.bas": "vb",
        "*.cls": "vb",
        "*.frm": "vb",
        "*.dcm": "vb",
        "*.txt": "vb" 
    },
    // Важно: Отключаем "умные" символы, которые ломают 1251
    "editor.smartQuotes": false,
    "editor.renderWhitespace": "all"
}